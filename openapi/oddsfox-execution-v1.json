{
  "components": {
    "responses": {
      "Error": {
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/ErrorEnvelope"
            }
          }
        },
        "description": "Stable error envelope"
      }
    },
    "schemas": {
      "CancellationRequest": {
        "additionalProperties": false,
        "properties": {
          "all_open_orders": {
            "default": false,
            "type": "boolean"
          },
          "condition_id": {
            "type": [
              "string",
              "null"
            ]
          },
          "intent_id": {
            "format": "uuid",
            "type": [
              "string",
              "null"
            ]
          },
          "order_id": {
            "format": "uuid",
            "type": [
              "string",
              "null"
            ]
          },
          "reason": {
            "maxLength": 512,
            "minLength": 1,
            "type": "string"
          }
        },
        "required": [
          "reason"
        ],
        "type": "object"
      },
      "ClientContext": {
        "additionalProperties": false,
        "properties": {
          "correlation_id": {
            "type": [
              "string",
              "null"
            ]
          },
          "strategy": {
            "type": [
              "string",
              "null"
            ]
          },
          "strategy_order_id": {
            "type": [
              "string",
              "null"
            ]
          }
        },
        "type": "object"
      },
      "DecimalString": {
        "pattern": "^[0-9]+(?:\\.[0-9]{1,6})?$",
        "type": "string"
      },
      "ErrorEnvelope": {
        "properties": {
          "error": {
            "properties": {
              "code": {
                "type": "string"
              },
              "correlation_id": {
                "format": "uuid",
                "type": "string"
              },
              "details": {
                "type": "object"
              },
              "message": {
                "type": "string"
              },
              "retryable": {
                "type": "boolean"
              }
            },
            "required": [
              "code",
              "message",
              "retryable",
              "correlation_id",
              "details"
            ],
            "type": "object"
          }
        },
        "required": [
          "error"
        ],
        "type": "object"
      },
      "OrderIntentRequest": {
        "additionalProperties": false,
        "properties": {
          "client_context": {
            "$ref": "#/components/schemas/ClientContext"
          },
          "condition_id": {
            "maxLength": 128,
            "type": "string"
          },
          "expires_at": {
            "format": "date-time",
            "type": [
              "string",
              "null"
            ]
          },
          "limit_price": {
            "oneOf": [
              {
                "$ref": "#/components/schemas/DecimalString"
              },
              {
                "type": "null"
              }
            ]
          },
          "post_only": {
            "default": false,
            "type": "boolean"
          },
          "quantity": {
            "$ref": "#/components/schemas/Quantity"
          },
          "side": {
            "enum": [
              "BUY",
              "SELL"
            ],
            "type": "string"
          },
          "time_in_force": {
            "enum": [
              "GTC",
              "GTD",
              "FOK",
              "FAK"
            ],
            "type": "string"
          },
          "token_id": {
            "maxLength": 128,
            "pattern": "^[0-9]+$",
            "type": "string"
          },
          "worst_price": {
            "oneOf": [
              {
                "$ref": "#/components/schemas/DecimalString"
              },
              {
                "type": "null"
              }
            ]
          }
        },
        "required": [
          "condition_id",
          "token_id",
          "side",
          "time_in_force",
          "quantity"
        ],
        "type": "object"
      },
      "Quantity": {
        "additionalProperties": false,
        "properties": {
          "unit": {
            "enum": [
              "shares",
              "quote"
            ],
            "type": "string"
          },
          "value": {
            "$ref": "#/components/schemas/DecimalString"
          }
        },
        "required": [
          "unit",
          "value"
        ],
        "type": "object"
      },
      "ReasonRequest": {
        "additionalProperties": false,
        "properties": {
          "reason": {
            "maxLength": 512,
            "minLength": 1,
            "type": "string"
          }
        },
        "required": [
          "reason"
        ],
        "type": "object"
      }
    },
    "securitySchemes": {
      "bearerAuth": {
        "scheme": "bearer",
        "type": "http"
      }
    }
  },
  "info": {
    "description": "Private, idempotent prediction-market execution control plane",
    "title": "OddsFox Execution API",
    "version": "1.0.0"
  },
